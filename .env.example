# Server
PORT=3000

# Session / Auth
SESSION_SECRET=change_this_to_a_random_secret_string
JWT_SECRET=change_this_to_a_random_jwt_secret_string

# Database (Local development)
DB_PATH=./data/pegangind.db

# Turso Database (Vercel production) — create at https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Midtrans (Sandbox/Production)
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=false

# Nodemailer (for client verification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_email_password

# App base URL (for Midtrans callbacks)
APP_BASE_URL=https://your-domain.vercel.app
