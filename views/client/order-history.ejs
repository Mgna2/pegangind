<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — pegangind.com</title>
  <link rel="icon" href="/assets/images/logo.png" type="image/png" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/main.css" />
  <link rel="stylesheet" href="/assets/css/animations.css" />
  <link rel="stylesheet" href="/assets/css/components.css" />
  <style>
    body { background: #f4f7fb; }

    /* Page wrapper */
    .oh-page {
      padding-top: 80px; /* navbar height */
      min-height: 100vh;
    }

    /* Top bar with user info + tabs */
    .oh-topbar {
      background: white;
      border-bottom: 1px solid #eef1f5;
      padding: 0 24px;
    }
    .oh-topbar-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      height: 60px;
      flex-wrap: wrap;
    }
    .oh-user {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .oh-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--brand-blue); color: white;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.9rem; flex-shrink: 0;
    }
    .oh-user-name { font-weight: 700; font-size: 0.9rem; color: var(--brand-navy); }
    .oh-user-email { font-size: 0.75rem; color: var(--text-muted); }

    /* Horizontal tabs */
    .oh-tabs {
      display: flex;
      gap: 0;
    }
    .oh-tab {
      display: flex; align-items: center; gap: 6px;
      padding: 6px 16px; font-size: 0.82rem; font-weight: 600;
      color: var(--text-muted); text-decoration: none; border-radius: 8px;
      transition: all 0.2s; border: none; background: none;
      font-family: inherit; cursor: pointer;
    }
    .oh-tab:hover { color: var(--brand-blue); background: #eff6ff; }
    .oh-tab.active { color: var(--brand-blue); background: #eff6ff; }
    .oh-tab svg { width: 15px; height: 15px; }

    /* Content */
    .oh-content {
      max-width: 900px;
      margin: 0 auto;
      padding: 28px 24px 60px;
    }

    /* Section header */
    .oh-section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
      flex-wrap: wrap;
      gap: 10px;
    }
    .oh-section-title { font-size: 1rem; font-weight: 800; color: var(--brand-navy); }
    .oh-section-count { font-size: 0.8rem; color: var(--text-muted); background: #f1f5f9; padding: 2px 10px; border-radius: 20px; }

    /* Filter tabs (Semua / Diproses / Selesai) */
    .filter-tabs { display: flex; gap: 4px; margin-bottom: 20px; background: white; padding: 4px; border-radius: 10px; border: 1px solid #eef1f5; }
    .filter-tab {
      flex: 1; text-align: center; padding: 7px 12px; border-radius: 8px;
      font-size: 0.8rem; font-weight: 600; color: var(--text-muted); text-decoration: none;
      transition: all 0.2s; border: none; background: none; font-family: inherit;
    }
    .filter-tab:hover { color: var(--brand-blue); }
    .filter-tab.active { background: var(--brand-blue); color: white; }

    /* Order cards */
    .order-card {
      background: white; border-radius: 12px; padding: 16px 20px;
      margin-bottom: 10px; border: 1px solid #eef1f5;
      transition: all 0.2s; cursor: pointer;
      display: block; text-decoration: none; color: inherit;
    }
    .order-card:hover { border-color: var(--brand-blue); box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-1px); }

    .oc-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; flex-wrap: wrap; gap: 6px; }
    .oc-id { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; font-weight: 700; color: var(--brand-blue); }
    .oc-date { font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; }
    .oc-badges { display: flex; gap: 5px; flex-wrap: wrap; }

    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; }
    .badge-green { background: #d4edda; color: #155724; }
    .badge-yellow { background: #fff3cd; color: #856404; }
    .badge-blue { background: #dbeafe; color: #1e40af; }
    .badge-orange { background: #fff7ed; color: #9a3412; }
    .badge-gray { background: #f1f5f9; color: #475569; }
    .badge-red { background: #fee2e2; color: #991b1b; }

    .oc-body { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 8px; }
    .oc-item { font-size: 0.85rem; }
    .oc-item-name { font-weight: 700; color: var(--brand-navy); }
    .oc-item-detail { font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; }
    .oc-total-label { font-size: 0.75rem; color: var(--text-muted); text-align: right; }
    .oc-total { font-size: 1rem; font-weight: 800; color: var(--brand-blue); }

    /* Empty state */
    .oh-empty { text-align: center; padding: 56px 20px; }
    .oh-empty svg { width: 52px; height: 52px; color: #d1d5db; margin-bottom: 16px; }
    .oh-empty h3 { font-size: 1rem; color: var(--brand-navy); margin-bottom: 6px; }
    .oh-empty p { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px; }

    @media (max-width: 600px) {
      .oh-topbar-inner { height: auto; padding: 12px 0; }
      .oh-tabs { flex-wrap: wrap; }
      .oh-content { padding: 20px 12px 60px; }
    }
  </style>
</head>
<body>
<%- include('../partials/navbar') %>

<div class="oh-page">
  <!-- Top bar: user info + tabs -->
  <div class="oh-topbar">
    <div class="oh-topbar-inner">
      <div class="oh-user">
        <div class="oh-avatar"><%= client.name.charAt(0).toUpperCase() %></div>
        <div>
          <div class="oh-user-name"><%= client.name %></div>
          <div class="oh-user-email"><%= client.email %></div>
        </div>
      </div>

      <nav class="oh-tabs">
        <a href="/akun" class="oh-tab">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Pengaturan
        </a>
        <a href="/akun/pesanan" class="oh-tab active">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Riwayat Pesanan
        </a>
        <a href="/chat" class="oh-tab">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Chat Admin
        </a>
      </nav>
    </div>
  </div>

  <!-- Content -->
  <div class="oh-content">
    <div class="oh-section-header">
      <div style="display:flex; align-items:center; gap:10px;">
        <span class="oh-section-title">Riwayat Pesanan</span>
        <% const totalOrders = orders.length; %>
        <% if (totalOrders > 0) { %>
          <span class="oh-section-count"><%= totalOrders %> pesanan</span>
        <% } %>
      </div>
    </div>

    <!-- Filter tabs -->
    <div class="filter-tabs">
      <a href="/akun/pesanan" class="filter-tab<%= activeTab === 'semua' ? ' active' : '' %>">Semua</a>
      <a href="/akun/pesanan?tab=diproses" class="filter-tab<%= activeTab === 'diproses' ? ' active' : '' %>">Diproses</a>
      <a href="/akun/pesanan?tab=selesai" class="filter-tab<%= activeTab === 'selesai' ? ' active' : '' %>">Selesai</a>
    </div>

    <%
      const prosesStatus = ['Pesanan Masuk', 'Sedang Dikerjakan', 'Sedang Dicetak', 'Siap Dikirim', 'Sudah Dikirim'];
      const selesaiStatus = ['Selesai'];
      let filtered = orders;
      if (activeTab === 'diproses') {
        filtered = orders.filter(o => prosesStatus.includes(o.status));
      } else if (activeTab === 'selesai') {
        filtered = orders.filter(o => selesaiStatus.includes(o.status));
      }
    %>

    <% if (filtered.length === 0) { %>
    <div class="oh-empty">
      <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <h3>Belum ada pesanan</h3>
      <p><%= activeTab === 'semua' ? 'Yuk mulai pesan pertama kamu!' : 'Pesanan di tab ini belum ada.' %></p>
      <a href="/keranjang" class="btn btn-primary btn-sm" style="display:inline-flex; gap:6px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
        Pesan Sekarang
      </a>
    </div>
    <% } else { %>

    <% filtered.forEach(order => { %>
    <%
      const statusBadge = {
        'Pesanan Masuk':     { cls: 'badge-yellow' },
        'Sedang Dikerjakan': { cls: 'badge-blue' },
        'Sedang Dicetak':   { cls: 'badge-blue' },
        'Selesai':          { cls: 'badge-green' },
        'Siap Dikirim':     { cls: 'badge-orange' },
        'Sudah Dikirim':    { cls: 'badge-green' },
      };
      const payBadge = {
        'pending': { cls: 'badge-yellow', label: 'Pending' },
        'paid':    { cls: 'badge-green', label: 'Lunas' },
        'expire':  { cls: 'badge-red', label: 'Expired' },
        'unpaid':  { cls: 'badge-red', label: 'Unpaid' },
      };
      const sb = statusBadge[order.status] || { cls: 'badge-gray' };
      const pb = payBadge[order.payment_status] || { cls: 'badge-gray', label: order.payment_status || '—' };
    %>
    <a href="/akun/pesanan/<%= order.id %>" class="order-card">
      <div class="oc-header">
        <div>
          <div class="oc-id"><%= order.order_id %></div>
          <div class="oc-date"><%= formatDate(order.created_at) %></div>
        </div>
        <div class="oc-badges">
          <span class="badge <%= sb.cls %>"><%= order.status %></span>
          <span class="badge <%= pb.cls %>"><%= pb.label %></span>
        </div>
      </div>
      <div class="oc-body">
        <div class="oc-item">
          <div class="oc-item-name"><%= order.material_type || order.material || '-' %></div>
          <div class="oc-item-detail">
            <%= order.layer_height ? order.layer_height + 'mm' : '' %>
            <%= order.gram_weight ? ' · ' + order.gram_weight + 'g' : '' %>
          </div>
        </div>
        <div style="text-align:right;">
          <div class="oc-total-label">Total</div>
          <div class="oc-total"><%= order.total_price ? 'Rp ' + order.total_price.toLocaleString('id-ID') : '-' %></div>
        </div>
      </div>
    </a>
    <% }); %>

    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
