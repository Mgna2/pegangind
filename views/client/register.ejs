<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — pegangind.com</title>
  <link rel="icon" href="/assets/images/logo.png" type="image/png" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/main.css" />
  <link rel="stylesheet" href="/assets/css/animations.css" />
  <link rel="stylesheet" href="/assets/css/components.css" />
  <link rel="stylesheet" href="/assets/css/admin.css" />
</head>
<body>
<div class="admin-login-page">
  <div class="blob blob-1" style="opacity: 0.2;"></div>
  <div class="blob blob-2" style="opacity: 0.15;"></div>

  <div class="login-card" style="position: relative; z-index: 2; max-width: 440px;">
    <img src="/assets/images/logo.png" alt="pegangind" class="logo" />
    <h2 style="text-align: center; margin-bottom: 4px; font-size: 1.5rem;">Buat Akun Baru</h2>
    <p style="text-align: center; color: var(--text-muted); font-size: 0.875rem; margin-bottom: 32px;">Daftar untuk mengakses chat & fitur lengkap</p>

    <form action="/daftar" method="POST" novalidate>
      <div class="form-group">
        <label class="form-label">Nama Lengkap</label>
        <input type="text" name="name" class="form-input" placeholder="Masukkan nama lengkap" required autocomplete="name"
          value="<%= (old && old.name) ? old.name : '' %>" />
        <% if (error && error.name) { %><span class="form-error"><%= error.name %></span><% } %>
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-input" placeholder="contoh@email.com" required autocomplete="email"
          value="<%= (old && old.email) ? old.email : '' %>" />
        <% if (error && error.email) { %><span class="form-error"><%= error.email %></span><% } %>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-input" placeholder="Minimal 6 karakter" required autocomplete="new-password" />
        <% if (error && error.password) { %><span class="form-error"><%= error.password %></span><% } %>
      </div>
      <div class="form-group">
        <label class="form-label">Konfirmasi Password</label>
        <input type="password" name="password2" class="form-input" placeholder="Ulangi password" required autocomplete="new-password" />
        <% if (error && error.password2) { %><span class="form-error"><%= error.password2 %></span><% } %>
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg" style="margin-top: 8px;">Daftar Sekarang</button>
    </form>

    <div class="login-divider"></div>
    <p style="text-align: center; font-size: 0.875rem; color: var(--text-muted);">
      Sudah punya akun? <a href="/masuk" style="color: var(--brand-blue); font-weight: 600;">Masuk</a>
    </p>
    <p style="text-align: center; font-size: 0.8rem; color: var(--text-muted); margin-top: 12px;">
      <a href="/" style="color: var(--brand-blue);">← Kembali ke Website</a>
    </p>
  </div>
</div>
</body>
</html>
