<div class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <img src="/assets/images/logo.png" alt="pegangind" />
    <span>Admin Panel</span>
  </div>
  <nav class="sidebar-nav">
    <p class="nav-section-title">Overview</p>
    <a href="/admin/dashboard" class="<%= typeof currentPage !== 'undefined' && currentPage === 'dashboard' ? 'active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <a href="/admin/chat" class="<%= typeof currentPage !== 'undefined' && currentPage === 'chat' ? 'active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Live Chat
    </a>
    <p class="nav-section-title">Pesanan</p>
    <a href="/admin/pesanan" class="<%= typeof currentPage !== 'undefined' && currentPage === 'orders' ? 'active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      Pesanan Shopee
    </a>
    <a href="/admin/pesanan-midtrans" class="<%= typeof currentPage !== 'undefined' && currentPage === 'midtrans-orders' ? 'active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      Pesanan Midtrans
    </a>
    <a href="/admin/pesanan/baru" class="<%= typeof currentPage !== 'undefined' && currentPage === 'order-new' ? 'active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Tambah Pesanan
    </a>
    <p class="nav-section-title">Konten</p>
    <a href="/admin/portofolio" class="<%= typeof currentPage !== 'undefined' && currentPage === 'portfolio' ? 'active' : '' %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      Kelola Portofolio
    </a>
    <p class="nav-section-title">Akun</p>
    <form action="/admin/logout" method="POST" style="margin: 0;">
      <button type="submit" style="width:100%; background:none; border:none; cursor:pointer; display:flex; align-items:center; gap:10px; padding:11px 14px; border-radius:10px; color:rgba(255,255,255,0.65); font-size:0.875rem; font-weight:500; transition:all 0.2s; text-align:left;" onmouseover="this.style.background='rgba(255,255,255,0.08)'; this.style.color='white'" onmouseout="this.style.background='none'; this.style.color='rgba(255,255,255,0.65)'">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Logout
      </button>
    </form>
  </nav>
  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="user-avatar"><%= typeof username !== 'undefined' ? username[0].toUpperCase() : 'A' %></div>
      <div>
        <div style="color:white; font-weight:600;"><%= typeof username !== 'undefined' ? username : 'Admin' %></div>
        <div style="font-size:0.7rem;">Administrator</div>
      </div>
    </div>
  </div>
</div>
