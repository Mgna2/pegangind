<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tambah Pesanan — pegangind Admin</title>
  <link rel="icon" href="/assets/images/logo.png" type="image/png" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/assets/css/main.css" />
  <link rel="stylesheet" href="/assets/css/animations.css" />
  <link rel="stylesheet" href="/assets/css/components.css" />
  <link rel="stylesheet" href="/assets/css/admin.css" />
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { currentPage: 'order-new' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="topbar-title">Tambah Pesanan Baru</div>
      <a href="/admin/pesanan" class="btn btn-ghost btn-sm">
        <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Kembali
      </a>
    </div>
    <div class="admin-content">
      <form action="/admin/pesanan" method="POST" enctype="multipart/form-data">
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
          <!-- Main Form -->
          <div>
            <div style="background: white; border-radius: var(--radius-lg); border: 1px solid #F1F5F9; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 24px;">
              <div class="form-card-header">
                <h3 style="display:flex; align-items:center; gap:8px;">
                  <i data-lucide="package" style="width:16px;height:16px;"></i> Informasi Pesanan
                </h3>
              </div>
              <div class="form-card-body">
                <div class="form-grid-2">
                  <div class="form-group">
                    <label class="form-label">ID Pesanan</label>
                    <input type="text" name="order_id" class="form-input" placeholder="Auto-generate jika kosong" style="font-family: 'JetBrains Mono', monospace;" />
                  </div>
                  <div class="form-group">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                      <% ['Pesanan Masuk','Sedang Dikerjakan','Sedang Dicetak','Selesai','Siap Dikirim','Sudah Dikirim'].forEach(s => { %>
                        <option value="<%= s %>"><%= s %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Nama Client *</label>
                    <input type="text" name="client_name" class="form-input" required placeholder="Nama lengkap" />
                  </div>
                  <div class="form-group">
                    <label class="form-label">WhatsApp</label>
                    <input type="text" name="whatsapp" class="form-input" placeholder="08xxxxxxxxxx" />
                  </div>
                  <div class="form-group">
                    <label class="form-label">Nomor Resi Shopee</label>
                    <input type="text" name="resi_shopee" class="form-input" placeholder="SNWAxxxxxxxxxxx" style="font-family: 'JetBrains Mono', monospace;" />
                  </div>
                  <div class="form-group">
                    <label class="form-label">Link Pesanan Shopee</label>
                    <input type="url" name="shopee_link" class="form-input" placeholder="https://shopee.co.id/..." />
                  </div>
                  <div class="form-group">
                    <label class="form-label">Material</label>
                    <select name="material" class="form-select">
                      <option value="">Pilih material...</option>
                      <option>PLA+</option>
                      <option>PETG</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label class="form-label">Warna Filament</label>
                    <input type="text" name="filament_color" class="form-input" placeholder="Merah, Hitam, Putih..." />
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label">Catatan Admin</label>
                  <textarea name="notes" class="form-textarea" rows="3" placeholder="Deskripsi order, instruksi khusus..."></textarea>
                </div>
                <div class="form-group">
                  <label class="form-label">Jumlah Pembayaran (Rp)</label>
                  <input type="number" name="amount" class="form-input" placeholder="ex: 150000" min="0" />
                </div>
              </div>
            </div>
          </div>

          <!-- Image Upload -->
          <div>
            <div style="background: white; border-radius: var(--radius-lg); border: 1px solid #F1F5F9; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.04);">
              <div class="form-card-header">
                <h3 style="display:flex; align-items:center; gap:8px;">
                  <i data-lucide="image" style="width:16px;height:16px;"></i> Upload Gambar
                </h3>
              </div>
              <div style="padding: 24px;">
                <div class="form-group">
                  <label class="form-label">Jenis Gambar</label>
                  <select name="image_type" class="form-select">
                    <option value="design">Desain / File</option>
                    <option value="process">Proses Cetak</option>
                    <option value="result">Hasil Akhir</option>
                    <option value="ready">Siap Kirim</option>
                  </select>
                </div>
                <div class="dropzone" id="dropzone">
                  <div class="dropzone-icon">
                    <i data-lucide="upload-cloud" style="width:36px;height:36px; color: var(--brand-blue); opacity:0.6;"></i>
                  </div>
                  <p style="font-weight: 600; margin-bottom: 4px;">Drag & Drop gambar di sini</p>
                  <p style="font-size: 0.8rem; color: var(--text-muted);">atau klik untuk browse</p>
                  <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 8px;">JPG, PNG, WebP — Maks 5MB/file</p>
                  <input type="file" name="images" multiple accept="image/*" style="display: none;" />
                </div>
                <div class="image-preview-grid"></div>
              </div>
            </div>
          </div>
        </div>

        <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px;">
          <a href="/admin/pesanan" class="btn btn-ghost btn-lg">Batal</a>
          <button type="submit" class="btn btn-primary btn-lg">
            <i data-lucide="save" style="width:16px;height:16px;"></i> Simpan Pesanan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<script src="/assets/js/admin.js"></script>
<script src="/assets/js/main.js"></script>
<script>lucide.createIcons();</script>
</body>
</html>
