<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<section style="padding: 140px 0 80px; background: linear-gradient(160deg, #FAFCFF 0%, var(--accent-light) 100%); text-align: center;">
  <div class="container">
    <span class="tag"><i data-lucide="image" style="width:12px;height:12px;"></i> Galeri</span>
    <h1 class="section-title reveal">Portofolio Hasil 3D Print</h1>
    <div class="divider reveal" style="margin: 16px auto;"></div>
    <p class="reveal" style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">Lihat semua hasil cetak 3D kami — dari figurine detail hingga komponen industri.</p>
  </div>
</section>

<section style="padding: 60px 0 100px;">
  <div class="container">
    <div class="portfolio-filters reveal">
      <button class="filter-btn active" data-filter="all">Semua</button>
      <button class="filter-btn" data-filter="figurine">Figurine</button>
      <button class="filter-btn" data-filter="mechanical">Mekanik</button>
      <button class="filter-btn" data-filter="prototype">Prototipe</button>
      <button class="filter-btn" data-filter="household">Household</button>
      <button class="filter-btn" data-filter="accessories">Aksesoris</button>
    </div>

    <div class="portfolio-grid" id="portfolioGrid">
      <% if (items && items.length > 0) { %>
        <% items.forEach((item, i) => { %>
          <div class="portfolio-item reveal" data-category="<%= item.category %>" style="transition-delay: <%= (i % 6) * 0.08 %>s">
            <% if (item.image_path) { %>
              <img src="<%= item.image_path %>" alt="<%= item.title %>" loading="lazy" onclick="openLightbox('<%= item.image_path %>', '<%= item.title %>')" />
            <% } else { %>
              <div class="portfolio-placeholder">
                <i data-lucide="printer" style="width:40px;height:40px;"></i>
                <span style="font-size:0.875rem; margin-top: 4px;"><%= item.title %></span>
              </div>
            <% } %>
            <div class="portfolio-overlay">
              <div style="font-size: 0.7rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 1px;"><%= item.category %></div>
              <div style="font-weight: 700; font-size: 1rem; margin-top: 4px;"><%= item.title %></div>
              <% if (item.description) { %><div style="font-size: 0.78rem; opacity: 0.82; margin-top: 4px;"><%= item.description %></div><% } %>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div style="grid-column: 1/-1; text-align: center; padding: 80px 0; color: var(--text-muted);">
          <i data-lucide="printer" style="width:48px;height:48px; margin-bottom: 16px; opacity: 0.4;"></i>
          <h3>Portofolio Akan Segera Hadir</h3>
          <p>Kami sedang menyiapkan galeri terbaik untuk kamu.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<script>lucide.createIcons();</script>
<script src="/assets/js/main.js"></script>
<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      document.querySelectorAll('.portfolio-item').forEach(item => {
        item.style.display = (filter === 'all' || item.dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>
</body>
</html>
