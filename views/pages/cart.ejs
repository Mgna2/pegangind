<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<section style="padding: 140px 0 80px; background: linear-gradient(160deg, #FAFCFF, var(--accent-light)); text-align: center;">
  <div class="container">
    <span class="tag"><i data-lucide="shopping-cart" style="width:12px;height:12px;"></i> Keranjang</span>
    <h1 class="section-title reveal">Keranjang Pesanan</h1>
    <p style="color: var(--text-muted);" class="reveal">Pilih material, resolusi, dan berat untuk menghitung harga.</p>
  </div>
</section>

<section style="padding: 60px 0 100px;">
  <div class="container">
    <% if (added) { %>
    <div class="glass-card reveal" style="padding: 20px 28px; margin-bottom: 24px; border-left: 4px solid #10b981; background: #f0fdf4;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <i data-lucide="check-circle" style="color: #10b981; width: 20px; height: 20px;"></i>
        <span style="color: #065f46; font-weight: 600;">Item berhasil ditambahkan ke keranjang!</span>
      </div>
    </div>
    <% } %>

    <% if (error === 'invalid') { %>
    <div class="glass-card" style="padding: 20px 28px; margin-bottom: 24px; border-left: 4px solid #ef4444; background: #fef2f2;">
      <span style="color: #991b1b; font-weight: 600;">Data tidak valid. Pastikan semua field terisi dengan benar.</span>
    </div>
    <% } %>

    <div style="display: grid; grid-template-columns: 1fr 380px; gap: 32px; align-items: start;">

      <!-- Left: Add Item Form + Cart Items -->
      <div>
        <!-- Add to Cart Form -->
        <div class="glass-card reveal" style="padding: 28px; margin-bottom: 24px;">
          <h3 style="margin-bottom: 20px; font-size: 1.05rem; display: flex; align-items: center; gap: 8px;">
            <i data-lucide="plus-circle" style="width:18px;height:18px; color: var(--brand-blue);"></i>
            Tambah Item
          </h3>
          <form action="/keranjang/tambah" method="POST" id="addToCartForm">
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 20px;">

              <div class="form-group">
                <label class="form-label">Material</label>
                <select name="material" id="materialSelect" class="form-select" required>
                  <option value="">Pilih Material</option>
                  <% MATERIALS.forEach(m => { %>
                    <option value="<%= m %>"><%= MATERIAL_LABELS[m] %></option>
                  <% }); %>
                </select>
              </div>

              <div class="form-group">
                <label class="form-label">Resolusi (mm)</label>
                <select name="layer_height" id="layerHeightSelect" class="form-select" required>
                  <option value="">Pilih Resolusi</option>
                  <% LAYER_HEIGHTS.forEach(lh => { %>
                    <option value="<%= lh %>"><%= lh %> mm</option>
                  <% }); %>
                </select>
              </div>

              <div class="form-group">
                <label class="form-label">Berat (gram)</label>
                <input type="number" name="gram_weight" id="gramWeightInput" class="form-input"
                  placeholder="cth: 50" min="1" step="0.1" required />
              </div>
            </div>

            <div id="pricePreview" style="display:none; padding: 16px; background: #F8FAFC; border-radius: 10px; margin-bottom: 20px; border: 1px solid #E5E7EB;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="color: var(--text-muted); font-size: 0.875rem;">Harga per gram:</span>
                <span id="unitPriceDisplay" style="font-weight: 700; color: var(--brand-blue);">Rp 0</span>
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px; padding-top: 8px; border-top: 1px dashed #D1D5DB;">
                <span style="font-weight: 600;">Estimasi Total:</span>
                <span id="totalPriceDisplay" style="font-weight: 800; font-size: 1.2rem; color: var(--brand-blue);">Rp 0</span>
              </div>
            </div>

            <button type="submit" class="btn btn-primary btn-md" style="width: 100%;">
              <i data-lucide="plus" style="width:16px;height:16px;"></i>
              Tambah ke Keranjang
            </button>
          </form>
        </div>

        <!-- Cart Items -->
        <% if (cart.length > 0) { %>
        <div class="glass-card reveal" style="padding: 28px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="font-size: 1.05rem; display: flex; align-items: center; gap: 8px;">
              <i data-lucide="list" style="width:18px;height:18px; color: var(--brand-blue);"></i>
              Item di Keranjang (<%= cart.length %>)
            </h3>
            <form action="/keranjang/clear" method="POST" onsubmit="return confirm('Kosongkan semua item?');">
              <button type="submit" class="btn btn-ghost btn-sm" style="color: #ef4444;">
                <i data-lucide="trash-2" style="width:14px;height:14px;"></i> Kosongkan
              </button>
            </form>
          </div>

          <% cart.forEach((item, idx) => { %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 0; <%= idx > 0 ? 'border-top: 1px solid #F1F5F9;' : '' %>">
            <div>
              <div style="font-weight: 700; font-size: 1rem; margin-bottom: 4px;">
                <span style="background: var(--brand-blue); color: white; padding: 2px 10px; border-radius: 20px; font-size: 0.75rem; margin-right: 8px;"><%= item.material %></span>
                <span style="color: var(--text-muted);">Layer <%= item.layerHeight %>mm</span>
              </div>
              <div style="color: var(--text-muted); font-size: 0.875rem;">
                <%= item.gramWeight %> gram × Rp <%= item.unitPrice.toLocaleString('id-ID') %>/gram
              </div>
            </div>
            <div style="text-align: right;">
              <div style="font-weight: 800; font-size: 1.1rem; color: var(--brand-blue); margin-bottom: 8px;">
                Rp <%= item.linePrice.toLocaleString('id-ID') %>
              </div>
              <form action="/keranjang/hapus" method="POST" style="display: inline;">
                <input type="hidden" name="itemId" value="<%= item.id %>" />
                <button type="submit" class="btn btn-ghost btn-sm" style="color: #ef4444; font-size: 0.75rem; padding: 4px 10px;">
                  <i data-lucide="x" style="width:12px;height:12px;"></i> Hapus
                </button>
              </form>
            </div>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <div class="glass-card reveal" style="padding: 60px 40px; text-align: center;">
          <div style="margin-bottom: 16px;">
            <i data-lucide="shopping-cart" style="width:48px;height:48px; color: #D1D5DB;"></i>
          </div>
          <h3 style="color: var(--text-muted); margin-bottom: 8px;">Keranjang kosong</h3>
          <p style="color: var(--text-muted); font-size: 0.875rem;">Tambahkan item menggunakan form di atas.</p>
        </div>
        <% } %>
      </div>

      <!-- Right: Order Summary -->
      <div>
        <div class="glass-card reveal" style="padding: 28px; position: sticky; top: 100px;">
          <h3 style="margin-bottom: 20px; font-size: 1.05rem; display: flex; align-items: center; gap: 8px;">
            <i data-lucide="receipt" style="width:18px;height:18px; color: var(--brand-blue);"></i>
            Ringkasan Pesanan
          </h3>

          <% if (cart.length > 0) { %>
          <div style="margin-bottom: 20px;">
            <% cart.forEach(item => { %>
            <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #F1F5F9; font-size: 0.875rem;">
              <span style="color: var(--text-body);"><%= item.material %> <%= item.layerHeight %>mm × <%= item.gramWeight %>g</span>
              <span style="font-weight: 600;">Rp <%= item.linePrice.toLocaleString('id-ID') %></span>
            </div>
            <% }); %>
          </div>

          <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px; background: var(--accent-light); border-radius: 10px; margin-bottom: 20px;">
            <span style="font-weight: 700; font-size: 1.1rem;">Total</span>
            <span style="font-weight: 800; font-size: 1.3rem; color: var(--brand-blue);">
              Rp <%= cart.reduce((s,i) => s + i.linePrice, 0).toLocaleString('id-ID') %>
            </span>
          </div>

          <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 20px; text-align: center;">
            Harga sudah termasuk biaya printing. Pembayaran via Midtrans.
          </p>

          <a href="/checkout" class="btn btn-primary btn-lg" style="width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px;">
            <i data-lucide="credit-card" style="width:18px;height:18px;"></i>
            Lanjut ke Checkout
          </a>
          <% } else { %>
          <div style="text-align: center; padding: 20px 0;">
            <p style="color: var(--text-muted); font-size: 0.875rem;">Belum ada item di keranjang.</p>
          </div>
          <% } %>

          <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid #F1F5F9;">
            <a href="/harga" style="display: flex; align-items: center; gap: 6px; font-size: 0.875rem; color: var(--brand-blue); font-weight: 600;">
              <i data-lucide="info" style="width:14px;height:14px;"></i>
              Lihat daftar harga material
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<script>lucide.createIcons();</script>
<script src="/assets/js/main.js"></script>

<script>
// Inject prices for JS
const _prices = <%- JSON.stringify(prices) %>;

function findPrice(material, layerHeight) {
  const row = _prices.find(p => p.material === material && p.layer_height === layerHeight);
  return row ? row.price_per_gram : null;
}

function updatePreview() {
  const mat = document.getElementById('materialSelect').value;
  const lh = document.getElementById('layerHeightSelect').value;
  const gram = parseFloat(document.getElementById('gramWeightInput').value);
  const preview = document.getElementById('pricePreview');

  if (!mat || !lh || !gram || gram <= 0) {
    preview.style.display = 'none';
    return;
  }

  const unit = findPrice(mat, lh);
  if (!unit) {
    preview.style.display = 'none';
    return;
  }

  const total = Math.round(unit * gram);
  document.getElementById('unitPriceDisplay').textContent = 'Rp ' + unit.toLocaleString('id-ID');
  document.getElementById('totalPriceDisplay').textContent = 'Rp ' + total.toLocaleString('id-ID');
  preview.style.display = 'block';
}

document.getElementById('materialSelect').addEventListener('change', updatePreview);
document.getElementById('layerHeightSelect').addEventListener('change', updatePreview);
document.getElementById('gramWeightInput').addEventListener('input', updatePreview);
</script>
</body>
</html>
