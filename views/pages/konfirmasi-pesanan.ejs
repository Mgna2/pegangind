<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<section style="padding: 140px 0 80px; background: linear-gradient(160deg, #FAFCFF, var(--accent-light)); text-align: center;">
  <div class="container">
    <% const isPaid = order.payment_status === 'paid'; %>
    <% const isPending = order.payment_status === 'pending'; %>
    <% const isExpire = order.payment_status === 'expire' || order.payment_status === 'unpaid'; %>

    <% if (isPaid) { %>
    <span class="tag" style="background: #dcfce7; color: #166534;"><i data-lucide="check-circle" style="width:12px;height:12px;"></i> Pembayaran Berhasil</span>
    <h1 class="section-title reveal" style="margin-top: 12px;">Pesanan Berhasil!</h1>
    <p style="color: var(--text-muted);" class="reveal">Pembayaran telah kami terima. Pesananmu sedang diproses.</p>
    <% } else if (isPending) { %>
    <span class="tag" style="background: #fffbeb; color: #92400e;"><i data-lucide="clock" style="width:12px;height:12px;"></i> Menunggu Pembayaran</span>
    <h1 class="section-title reveal" style="margin-top: 12px;">Pesanan Pending</h1>
    <p style="color: var(--text-muted);" class="reveal">Selesaikan pembayaran untuk memproses pesananmu.</p>
    <% } else { %>
    <span class="tag" style="background: #fef2f2; color: #991b1b;"><i data-lucide="x-circle" style="width:12px;height:12px;"></i> Pembayaran Kadaluarsa</span>
    <h1 class="section-title reveal" style="margin-top: 12px;">Pembayaran Kadaluarsa</h1>
    <p style="color: var(--text-muted);" class="reveal">Silakan buat pesanan baru atau coba ulangi pembayaran.</p>
    <% } %>
  </div>
</section>

<section style="padding: 60px 0 100px;">
  <div class="container">
    <div style="max-width: 720px; margin: 0 auto;">

      <!-- Order Details Card -->
      <div class="glass-card reveal" style="padding: 32px; margin-bottom: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px; margin-bottom: 28px;">
          <div>
            <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 6px;">ID Pesanan</div>
            <div style="font-weight: 800; font-size: 1.4rem; font-family: 'JetBrains Mono', monospace; color: var(--brand-blue);"><%= order.order_id %></div>
            <% if (order.midtrans_order_id) { %>
            <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 4px; font-family: 'JetBrains Mono', monospace;">
              Midtrans: <%= order.midtrans_order_id %>
            </div>
            <% } %>
          </div>
          <div style="text-align: right;">
            <% const statusBadge = isPaid ? {cls:'green', label:'Lunas'} : isPending ? {cls:'orange', label:'Pending'} : {cls:'red', label:'Expired'}; %>
            <span class="badge badge-<%= statusBadge.cls %>"><%= statusBadge.label %></span>
            <% if (isPending) { %>
            <button id="continuePayBtn" class="btn btn-primary btn-sm" style="margin-top: 12px; display: inline-flex; align-items: center; gap: 6px;">
              <i data-lucide="credit-card" style="width:12px;height:12px;"></i> Bayar Sekarang
            </button>
            <% } %>
          </div>
        </div>

        <!-- Items -->
        <% if (allItems.length > 0) { %>
        <div style="margin-bottom: 24px;">
          <h4 style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 12px;">Item Pesanan</h4>
          <% allItems.forEach(item => { %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: #F8FAFC; border-radius: 10px; margin-bottom: 8px;">
            <div>
              <div style="font-weight: 600; font-size: 0.9rem;">
                <span style="background: var(--brand-blue); color: white; padding: 1px 8px; border-radius: 20px; font-size: 0.7rem; margin-right: 8px;"><%= item.material_type || item.material %></span>
                Layer <%= item.layer_height || '-' %> mm
              </div>
              <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 2px;">
                <%= item.gram_weight ? item.gram_weight + ' gram' : '-' %> —
                Status Pesanan: <strong><%= item.status %></strong>
              </div>
            </div>
            <div style="font-weight: 800; color: var(--brand-blue);">
              Rp <%= (item.total_price || 0).toLocaleString('id-ID') %>
            </div>
          </div>
          <% }); %>

          <div style="display: flex; justify-content: flex-end; padding-top: 12px;">
            <div style="text-align: right;">
              <div style="font-size: 0.75rem; color: var(--text-muted);">Total Pembayaran</div>
              <div style="font-weight: 800; font-size: 1.5rem; color: var(--brand-blue);">
                Rp <%= (order.total_price || 0).toLocaleString('id-ID') %>
              </div>
            </div>
          </div>
        </div>
        <% } %>

        <!-- Client Info -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div>
            <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 4px;">Nama Pemesan</div>
            <div style="font-weight: 600;"><%= order.client_name %></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 4px;">WhatsApp</div>
            <div style="font-weight: 600;"><%= order.whatsapp || '-' %></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 4px;">Email</div>
            <div style="font-weight: 600;"><%= order.email || '-' %></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 4px;">Tanggal Pesan</div>
            <div style="font-weight: 600;"><%= new Date(order.created_at).toLocaleDateString('id-ID', {day:'2-digit',month:'long',year:'numeric'}) %></div>
          </div>
        </div>

        <% if (order.notes) { %>
        <div style="margin-top: 16px; padding: 12px 16px; background: #F8FAFC; border-radius: 10px;">
          <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 4px;">Catatan</div>
          <div style="font-size: 0.875rem; color: var(--text-body);"><%= order.notes %></div>
        </div>
        <% } %>
      </div>

      <!-- Actions -->
      <div class="glass-card reveal" style="padding: 24px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="/cek-pesanan" class="btn btn-primary btn-md" style="display: inline-flex; align-items: center; gap: 8px;">
          <i data-lucide="search" style="width:16px;height:16px;"></i>
          Lacak Pesanan
        </a>
        <a href="/" class="btn btn-ghost btn-md">
          Kembali ke Beranda
        </a>
      </div>

    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<script src="https://app.sandbox.midtrans.com/snap/snap.js" data-client-key="<%= midtransClientKey %>"></script>
<script>lucide.createIcons();</script>
<script src="/assets/js/main.js"></script>
<script>
  const continuePayBtn = document.getElementById('continuePayBtn');
  if (continuePayBtn) {
    continuePayBtn.addEventListener('click', async () => {
      continuePayBtn.disabled = true;
      continuePayBtn.innerHTML = '<span class="spinner"></span> Memuat...';
      try {
        const res = await fetch('/api/midtrans/pay-link?order_id=<%= order.midtrans_order_id %>');
        const data = await res.json();
        if (data.success && data.token) {
          window.snap.pay(data.token, {
            onSuccess: () => window.location.reload(),
            onPending: () => window.location.reload(),
            onError: () => { alert('Pembayaran gagal.'); continuePayBtn.disabled = false; continuePayBtn.innerHTML = '<i data-lucide="credit-card" style="width:12px;height:12px;"></i> Bayar Sekarang'; lucide.createIcons(); },
            onClose: () => { continuePayBtn.disabled = false; continuePayBtn.innerHTML = '<i data-lucide="credit-card" style="width:12px;height:12px;"></i> Bayar Sekarang'; lucide.createIcons(); },
          });
        } else {
          alert(data.error || 'Gagal membuat link pembayaran.');
          continuePayBtn.disabled = false;
          continuePayBtn.innerHTML = '<i data-lucide="credit-card" style="width:12px;height:12px;"></i> Bayar Sekarang';
        }
      } catch (e) {
        alert('Terjadi kesalahan. Silakan coba lagi.');
        continuePayBtn.disabled = false;
        continuePayBtn.innerHTML = '<i data-lucide="credit-card" style="width:12px;height:12px;"></i> Bayar Sekarang';
      }
    });
  }
</script>
</body>
</html>
