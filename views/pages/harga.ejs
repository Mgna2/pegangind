<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<section style="padding: 140px 0 80px; background: linear-gradient(160deg, #FAFCFF, var(--accent-light)); text-align: center;">
  <div class="container">
    <span class="tag"><i data-lucide="receipt" style="width:12px;height:12px;"></i> Harga Transparan</span>
    <h1 class="section-title reveal">Price List Jasa 3D Printing</h1>
    <div class="divider reveal" style="margin: 16px auto;"></div>
    <p class="reveal" style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">Harga dihitung per gram berdasarkan material dan resolusi cetak (layer height).</p>
  </div>
</section>

<section style="padding: 60px 0 100px;">
  <div class="container">
    <!-- Materials Price Tables -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 28px; max-width: 900px; margin: 0 auto 60px;">

      <!-- PLA -->
      <div class="reveal">
        <div style="background: var(--brand-blue); color: white; padding: 18px 28px; border-radius: var(--radius-md) var(--radius-md) 0 0; font-weight: 700; font-size: 1.05rem; display: flex; align-items: center; gap: 10px;">
          <i data-lucide="layers" style="width:18px;height:18px;"></i>
          Material PLA
        </div>
        <div style="background: white; border: 1px solid #E5E7EB; border-top: none; border-radius: 0 0 var(--radius-md) var(--radius-md); overflow: hidden; box-shadow: 0 8px 32px rgba(18,72,117,0.1);">
          <div style="display: flex; justify-content: space-between; padding: 12px 24px; background: #F8FAFC; font-size: 0.78rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.8px; border-bottom: 1px solid #E5E7EB;">
            <span>Resolusi</span><span>Harga / gram</span>
          </div>
          <% [
            ['0.08 mm','699'],
            ['0.10 mm','499'],
            ['0.12 mm','449'],
            ['0.15 mm','399'],
            ['0.20 mm','349'],
            ['0.22 mm','299'],
          ].forEach(([res, harga], i) => { %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px 24px; border-bottom: 1px solid #F1F5F9; transition: background 0.15s;" onmouseover="this.style.background='#F8FAFC'" onmouseout="this.style.background=''">
            <span style="font-size: 0.9rem; color: var(--text-body);"><%= res %></span>
            <span style="font-weight: 700; color: var(--brand-blue); font-size: 0.95rem;">Rp <%= harga %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- PETG -->
      <div class="reveal reveal-delay-1">
        <div style="background: var(--brand-blue); color: white; padding: 18px 28px; border-radius: var(--radius-md) var(--radius-md) 0 0; font-weight: 700; font-size: 1.05rem; display: flex; align-items: center; gap: 10px;">
          <i data-lucide="layers" style="width:18px;height:18px;"></i>
          Material PETG
        </div>
        <div style="background: white; border: 1px solid #E5E7EB; border-top: none; border-radius: 0 0 var(--radius-md) var(--radius-md); overflow: hidden; box-shadow: 0 8px 32px rgba(18,72,117,0.1);">
          <div style="display: flex; justify-content: space-between; padding: 12px 24px; background: #F8FAFC; font-size: 0.78rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.8px; border-bottom: 1px solid #E5E7EB;">
            <span>Resolusi</span><span>Harga / gram</span>
          </div>
          <% [
            ['0.08 mm','799'],
            ['0.10 mm','660'],
            ['0.12 mm','590'],
            ['0.15 mm','540'],
            ['0.20 mm','490'],
            ['0.22 mm','360'],
          ].forEach(([res, harga]) => { %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px 24px; border-bottom: 1px solid #F1F5F9; transition: background 0.15s;" onmouseover="this.style.background='#F8FAFC'" onmouseout="this.style.background=''">
            <span style="font-size: 0.9rem; color: var(--text-body);"><%= res %></span>
            <span style="font-weight: 700; color: var(--brand-blue); font-size: 0.95rem;">Rp <%= harga %></span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Info note -->
    <div class="reveal" style="max-width: 900px; margin: 0 auto 60px;">
      <div style="background: var(--accent-light); border: 1px solid rgba(18,72,117,0.15); border-radius: var(--radius-md); padding: 20px 24px; display: flex; gap: 14px; align-items: flex-start;">
        <i data-lucide="info" style="width:20px;height:20px; color: var(--brand-blue); flex-shrink:0; margin-top:2px;"></i>
        <div>
          <div style="font-weight: 700; margin-bottom: 4px; color: var(--brand-blue);">Cara Perhitungan Harga</div>
          <div style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.7;">
            Harga akhir = <strong>berat file (gram) × harga/gram</strong> (berdasarkan material dan resolusi). Berat file bisa di-estimasi dari slicer seperti Cura atau PrusaSlicer. Pengiriman via Shopee atau JNE/SiCepat menyesuaikan berat.
          </div>
        </div>
      </div>
    </div>

    <!-- Material Comparison -->
    <div class="admin-table-wrapper reveal" style="max-width: 900px; margin: 0 auto;">
      <div class="table-header">
        <h3>Perbandingan Material</h3>
      </div>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Material</th>
            <th>Kekuatan</th>
            <th>Fleksibilitas</th>
            <th>Cocok Untuk</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>PLA</strong></td>
            <td><span style="color: var(--brand-green);">★★★</span>☆☆</td>
            <td><span style="color: var(--brand-green);">★</span>☆☆☆☆</td>
            <td>Figurine, dekorasi, prototipe visual</td>
          </tr>
          <tr>
            <td><strong>PETG</strong></td>
            <td><span style="color: var(--brand-green);">★★★★</span>☆</td>
            <td><span style="color: var(--brand-green);">★★★</span>☆☆</td>
            <td>Parts fungsional, waterproof, outdoor</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- CTA -->
<section style="background: var(--brand-blue); padding: 80px 0; text-align: center;">
  <div class="container reveal">
    <h2 style="color: white; margin-bottom: 12px;">Tidak yakin pilih material atau resolusi apa?</h2>
    <p style="color: rgba(255,255,255,0.75); margin-bottom: 32px;">Konsultasikan gratis dengan tim kami — kami bantu hitung estimasi harga.</p>
    <a href="/kontak" class="btn btn-lg" style="background: var(--brand-green); color: #1a1a1a; font-weight: 700;">
      <i data-lucide="message-circle" style="width:18px;height:18px;"></i>
      Konsultasi Gratis
    </a>
  </div>
</section>

<%- include('../partials/footer') %>
<script>lucide.createIcons();</script>
<script src="/assets/js/main.js"></script>
</body>
</html>
